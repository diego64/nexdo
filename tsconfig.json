{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@dominio/*": ["src/dominio/*"],
      "@aplicacao/*": ["src/aplicacao/*"],
      "@infraestrutura/*": ["src/infraestrutura/*"],
      "@compartilhado/*": ["src/compartilhado/*"]
    }
  },
  "include": ["src", "testes", "scripts"],
  "exclude": ["node_modules", "dist"]
}
