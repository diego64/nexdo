# ======== Aplicação ========
# ⚠️ Este arquivo é um MODELO versionado — use SÓ placeholders, nunca segredos reais.
# Copie para `.env` (git-ignored) e preencha os valores locais reais (ver CLAUDE.md §7).
NODE_ENV=development
PORTA=3333
CORS_ORIGENS=http://localhost:3000

# ======== JWT ========
# Nome alinhado ao secret de produção: JWT_SECRET
JWT_SECRET=troque-este-segredo-no-env-local
JWT_EXPIRACAO=15m

# ======== PostgreSQL (local — Supabase em produção via DATABASE_URL) ========
# A app lê DATABASE_URL (mesmo nome do secret de produção).
# POSTGRES_* servem apenas para subir o container local via docker-compose.
POSTGRES_USER=administrador
POSTGRES_PASSWORD=TROQUE_NO_ENV_LOCAL
POSTGRES_DB=nexdo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://administrador:TROQUE_NO_ENV_LOCAL@localhost:5432/nexdo

# ======== MongoDB (auditoria) ========
# A app lê MONGODB_URI (mesmo nome do secret de produção).
# MONGO_INITDB_* servem apenas para o container local via docker-compose.
MONGO_INITDB_ROOT_USERNAME=administrador
MONGO_INITDB_ROOT_PASSWORD=TROQUE_NO_ENV_LOCAL
MONGO_INITDB_DATABASE=nexdo_audit
MONGODB_URI=mongodb://administrador:TROQUE_NO_ENV_LOCAL@localhost:27017/nexdo_audit?authSource=admin

# ======== Supabase (produção) ========
# Só é necessário se algum trecho usar o SDK JS do Supabase.
# O acesso ao banco é via DATABASE_URL (driver pg nativo) — ver CLAUDE.md §2.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=troque-no-env-local

# ======== Observabilidade ========
GRAFANA_USER=administrador
GRAFANA_PASSWORD=TROQUE_NO_ENV_LOCAL
LOKI_URL=http://localhost:3100
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nexdo-api

# ======== CI / Registry (secrets do GitHub Actions — NÃO usados no runtime da app) ========
# DOCKER_USER=
# DOCKER_TOKEN=
