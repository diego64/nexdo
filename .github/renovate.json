{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "timezone": "America/Sao_Paulo",
  "schedule": ["before 7am on monday"],
  "labels": ["dependencias"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": true },
  "packageRules": [
    {
      "description": "Agrupa atualizações minor e patch em um único PR",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dependências (minor e patch)"
    },
    {
      "description": "Major exige revisão individual",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencias", "breaking-change"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["seguranca"]
  }
}
